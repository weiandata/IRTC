## Rcpp / RcppArmadillo are linked automatically via LinkingTo; the explicit
## Rcpp:::LdFlags() call has been unnecessary since 2013 (and is being removed).
CXX_STD = CXX17
PKG_CPPFLAGS = -DBOOST_NO_LONG_LONG -DBOOST_NO_AUTO_PTR -DRCPP_USE_UNWIND_PROTECT
PKG_LIBS = -pthread
